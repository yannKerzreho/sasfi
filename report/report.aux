\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces DGP specification experiment — Heavy-tailed noise. DGP: SAS\textsubscript  {q2} ($p{=}1$, $n{=}50$, $\rho {=}0.95$), noise $\mathcal  {D} = t(5)$, no clipping, $N_\text  {gen}{=}4{,}000$. Evaluated over $N{=}56$ symbol-seed runs. SAS DGP is the exact oracle floor ($\mathrm  {MSE}_\text  {oracle} = \hat  \sigma ^2\cdot \nu /(\nu {-}2)$). MCS uses $\alpha {=}0.10$ and $B{=}1000$ bootstraps, with losses row-normalised.}}{6}{table.4}\protected@file@percent }
\newlabel{tab:dgp_t5}{{4}{6}{DGP specification experiment — Heavy-tailed noise. DGP: SAS\textsubscript {q2} ($p{=}1$, $n{=}50$, $\rho {=}0.95$), noise $\mathcal {D} = t(5)$, no clipping, $N_\text {gen}{=}4{,}000$. Evaluated over $N{=}56$ symbol-seed runs. SAS DGP is the exact oracle floor ($\mathrm {MSE}_\text {oracle} = \hat \sigma ^2\cdot \nu /(\nu {-}2)$). MCS uses $\alpha {=}0.10$ and $B{=}1000$ bootstraps, with losses row-normalised}{table.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces DGP specification experiment — Gaussian noise. DGP: SAS\textsubscript  {q2} ($p{=}1$, $n{=}50$, $\rho {=}0.95$), noise $\mathcal  {D} = \mathcal  {N}(0, 1)$, no clipping, $N_\text  {gen}{=}4{,}000$. Evaluated over $N{=}69$ symbol-seed runs. SAS DGP is the exact oracle floor ($\mathrm  {MSE}_\text  {oracle} = \hat  \sigma ^2$). MCS uses $\alpha {=}0.10$ and $B{=}1000$ bootstraps, with losses row-normalised.}}{7}{table.5}\protected@file@percent }
\newlabel{tab:dgp_gaussian}{{5}{7}{DGP specification experiment — Gaussian noise. DGP: SAS\textsubscript {q2} ($p{=}1$, $n{=}50$, $\rho {=}0.95$), noise $\mathcal {D} = \mathcal {N}(0, 1)$, no clipping, $N_\text {gen}{=}4{,}000$. Evaluated over $N{=}69$ symbol-seed runs. SAS DGP is the exact oracle floor ($\mathrm {MSE}_\text {oracle} = \hat \sigma ^2$). MCS uses $\alpha {=}0.10$ and $B{=}1000$ bootstraps, with losses row-normalised}{table.5}{}}
